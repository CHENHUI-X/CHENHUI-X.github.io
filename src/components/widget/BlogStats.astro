---
interface Props {
	postCount: number;
	tagCount: number;
	totalWords: number;
	foundedDate: string; // 建站日期，格式 YYYY-MM-DD
	lastUpdated: string; // 最后更新，格式 YYYY-MM-DD
	runningDays: number;
}

const {
	postCount,
	tagCount,
	totalWords,
	foundedDate,
	lastUpdated,
	runningDays,
} = Astro.props;

// 书籍数据集：按字数升序排列
const BOOKS: { title: string; words: number; lang: string }[] = [
	{ title: "《长恨歌》", words: 840, lang: "zh" },
	{ title: "《诗经》名篇选", words: 2000, lang: "zh" },
	{ title: "《道德经》", words: 5000, lang: "zh" },
	{ title: "《论语》", words: 16000, lang: "zh" },
	{ title: "The Little Prince", words: 20000, lang: "en" },
	{ title: "《边城》", words: 30000, lang: "zh" },
	{ title: "《老人与海》", words: 40000, lang: "zh" },
	{ title: "The Great Gatsby", words: 47000, lang: "en" },
	{ title: "《局外人》", words: 50000, lang: "zh" },
	{ title: "《城南旧事》", words: 60000, lang: "zh" },
	{ title: "The Catcher in the Rye", words: 73000, lang: "en" },
	{ title: "1984", words: 89000, lang: "en" },
	{ title: "To Kill a Mockingbird", words: 100000, lang: "en" },
	{ title: "《活着》", words: 120000, lang: "zh" },
	{ title: "Pride and Prejudice", words: 122000, lang: "en" },
	{ title: "《围城》", words: 170000, lang: "zh" },
	{ title: "《三体》第一部", words: 200000, lang: "zh" },
	{ title: "《白夜行》", words: 250000, lang: "zh" },
	{ title: "《平凡的世界》", words: 300000, lang: "zh" },
	{ title: "《百年孤独》", words: 350000, lang: "zh" },
	{ title: "Gone with the Wind", words: 400000, lang: "en" },
	{ title: "The Lord of the Rings", words: 455000, lang: "en" },
	{ title: "《三国演义》", words: 486000, lang: "zh" },
	{ title: "Les Misérables", words: 530000, lang: "en" },
	{ title: "《西游记》", words: 560000, lang: "zh" },
	{ title: "War and Peace", words: 587000, lang: "en" },
	{ title: "《红楼梦》", words: 730000, lang: "zh" },
];

// 找到字数最接近的书籍并生成对比文案
function findBookComparison(totalWords: number): string {
	if (totalWords === 0) return "还没有内容，快开始写吧 ✍️";

	let closest = BOOKS[0];
	let minDiff = Math.abs(totalWords - closest.words);

	for (const book of BOOKS) {
		const diff = Math.abs(totalWords - book.words);
		if (diff < minDiff) {
			minDiff = diff;
			closest = book;
		}
	}

	const ratio = totalWords / closest.words;

	if (ratio >= 0.95 && ratio <= 1.05) {
		return `恰好相当于${closest.title}`;
	}
	if (ratio >= 0.65 && ratio < 0.95) {
		return `接近${closest.title}了`;
	}
	if (ratio >= 0.35 && ratio < 0.65) {
		return `相当于${closest.title}的一半`;
	}
	return `已经超过了${closest.title}`;
}

const formattedWords = totalWords.toLocaleString("zh-CN");
const equivalent = findBookComparison(totalWords);
---

<div class="blog-stats-grid">
    <div class="stat-item">
        <span class="stat-icon">📝</span>
        <span class="stat-label">文章总数</span>
        <span class="stat-value">{postCount} 篇</span>
    </div>
    <div class="stat-item">
        <span class="stat-icon">🏷️</span>
        <span class="stat-label">标签总数</span>
        <span class="stat-value">{tagCount} 个</span>
    </div>
    <div class="stat-item">
        <span class="stat-icon">✍️</span>
        <span class="stat-label">全站字数</span>
        <span class="stat-value">约 {formattedWords} 字</span>
    </div>
    <div class="stat-item">
        <span class="stat-icon">📚</span>
        <span class="stat-label">内容产量</span>
        <span class="stat-value">{equivalent}</span>
    </div>
    <div class="stat-item">
        <span class="stat-icon">📅</span>
        <span class="stat-label">建站时间</span>
        <span class="stat-value">{foundedDate}</span>
    </div>
    <div class="stat-item">
        <span class="stat-icon">⏱️</span>
        <span class="stat-label">已运行</span>
        <span class="stat-value">{runningDays} 天</span>
    </div>
    <div class="stat-item stat-item--wide">
        <span class="stat-icon">🔄</span>
        <span class="stat-label">最后更新</span>
        <span class="stat-value">{lastUpdated}</span>
    </div>
</div>

<style>
.blog-stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin: 1.5rem 0 0.5rem;
}

.stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    padding: 0.9rem 0.75rem;
    border-radius: 0.75rem;
    background: var(--btn-regular-bg);
    transition: transform 300ms cubic-bezier(0.34, 1.56, 0.64, 1),
                box-shadow 300ms cubic-bezier(0.16, 1, 0.3, 1);
    text-align: center;
}

.stat-item:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
}

/* 占满整行 */
.stat-item--wide {
    grid-column: 1 / -1;
    flex-direction: row;
    justify-content: center;
    gap: 0.6rem;
    align-items: center;
}

.stat-icon {
    font-size: 1.4rem;
    line-height: 1;
}

.stat-label {
    font-size: 0.75rem;
    color: var(--text-color-lighten);
    opacity: 0.7;
}

.stat-value {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--primary);
}

.stat-item--wide .stat-label {
    font-size: 0.85rem;
}

.stat-item--wide .stat-value {
    font-size: 0.95rem;
}
</style>
