---
interface Props {
    postCount: number;
    tagCount: number;
    totalWords: number;
    foundedDate: string;   // 建站日期，格式 YYYY-MM-DD
    lastUpdated: string;   // 最后更新，格式 YYYY-MM-DD
    runningDays: number;
}

const { postCount, tagCount, totalWords, foundedDate, lastUpdated, runningDays } = Astro.props;

// 字数对应的书籍类比
function wordEquivalent(words: number): string {
    if (words < 3000)  return "刚够一篇课程报告 📄";
    if (words < 10000) return "约等于一篇期末论文 📝";
    if (words < 30000) return "快赶上一篇毕业论文了 🎓";
    if (words < 80000) return "相当于半本小说 📖";
    if (words < 200000) return "快写完一本书了 📚";
    return "著作等身，大佬！🏆";
}

const formattedWords = totalWords.toLocaleString("zh-CN");
const equivalent = wordEquivalent(totalWords);
---

<div class="blog-stats-grid">
    <div class="stat-item">
        <span class="stat-icon">📝</span>
        <span class="stat-label">文章总数</span>
        <span class="stat-value">{postCount} 篇</span>
    </div>
    <div class="stat-item">
        <span class="stat-icon">🏷️</span>
        <span class="stat-label">标签总数</span>
        <span class="stat-value">{tagCount} 个</span>
    </div>
    <div class="stat-item">
        <span class="stat-icon">✍️</span>
        <span class="stat-label">全站字数</span>
        <span class="stat-value">约 {formattedWords} 字</span>
    </div>
    <div class="stat-item stat-item--wide">
        <span class="stat-icon">📚</span>
        <span class="stat-label">内容产量</span>
        <span class="stat-value">{equivalent}</span>
    </div>
    <div class="stat-item">
        <span class="stat-icon">📅</span>
        <span class="stat-label">建站时间</span>
        <span class="stat-value">{foundedDate}</span>
    </div>
    <div class="stat-item">
        <span class="stat-icon">⏱️</span>
        <span class="stat-label">已运行</span>
        <span class="stat-value">{runningDays} 天</span>
    </div>
    <div class="stat-item stat-item--wide">
        <span class="stat-icon">🔄</span>
        <span class="stat-label">最后更新</span>
        <span class="stat-value">{lastUpdated}</span>
    </div>
</div>

<style>
.blog-stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin: 1.5rem 0 0.5rem;
}

.stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    padding: 0.9rem 0.75rem;
    border-radius: 0.75rem;
    background: var(--btn-regular-bg);
    transition: transform 300ms cubic-bezier(0.34, 1.56, 0.64, 1),
                box-shadow 300ms cubic-bezier(0.16, 1, 0.3, 1);
    text-align: center;
}

.stat-item:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
}

/* 占满整行 */
.stat-item--wide {
    grid-column: 1 / -1;
    flex-direction: row;
    justify-content: center;
    gap: 0.6rem;
    align-items: center;
}

.stat-icon {
    font-size: 1.4rem;
    line-height: 1;
}

.stat-label {
    font-size: 0.75rem;
    color: var(--text-color-lighten);
    opacity: 0.7;
}

.stat-value {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--primary);
}

.stat-item--wide .stat-label {
    font-size: 0.85rem;
}

.stat-item--wide .stat-value {
    font-size: 0.95rem;
}
</style>
