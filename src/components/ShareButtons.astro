---
import { Icon } from "astro-icon/components";

const { title, url } = Astro.props;

const urlStr = typeof url === "string" ? url : url.toString();
const encodedTitle = encodeURIComponent(title);
const encodedUrl = encodeURIComponent(urlStr);
const fullText = `${encodedTitle}%0A${encodedUrl}`;
const qrSrc = `https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=${encodedUrl}`;

const shareLinks = [
	{
		name: "Twitter",
		icon: "fa6-brands:square-x-twitter",
		href: `https://twitter.com/intent/tweet?text=${fullText}`,
	},
	{
		name: "Facebook",
		icon: "fa6-brands:facebook",
		href: `https://www.facebook.com/sharer/sharer.php?title=${encodedTitle}&u=${encodedUrl}`,
	},
	{
		name: "Telegram",
		icon: "fa6-brands:telegram",
		href: `https://t.me/share/url?url=${encodedUrl}&text=${encodedTitle}`,
	},
	{
		name: "WeChat",
		icon: "fa6-brands:weixin",
		wechat: true,
	},
];
---

<div class="share-buttons flex items-center gap-2 mt-6 pt-5 border-t border-dashed border-[var(--line-divider)]">
	<span class="text-sm text-[var(--secondary)] mr-1">分享</span>
	{shareLinks.map((link) =>
		link.wechat ? (
			<button
				type="button"
				id="wechat-share-btn"
				class="btn-regular rounded-lg h-9 w-9 active:scale-90 cursor-pointer"
				title="WeChat"
				aria-label="Share to WeChat"
				onclick="document.getElementById('wechat-overlay').style.display='flex'"
			>
				<Icon name={link.icon} class="text-[1.2rem]" />
			</button>
		) : (
			<a
				href={link.href}
				target="_blank"
				rel="noopener noreferrer"
				class="btn-regular rounded-lg h-9 w-9 active:scale-90"
				title={link.name}
				aria-label={`Share to ${link.name}`}
			>
				<Icon name={link.icon} class="text-[1.2rem]" />
			</a>
		)
	)}
</div>

<div id="wechat-overlay"
	style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.5);align-items:center;justify-content:center"
	onclick="this.style.display='none'"
>
	<div
		style="background:white;border-radius:16px;padding:24px;box-shadow:0 20px 60px rgba(0,0,0,0.3);display:flex;flex-direction:column;align-items:center;min-width:260px"
		onclick="event.stopPropagation()"
	>
		<div style="font-size:14px;font-weight:500;margin-bottom:12px;color:rgba(0,0,0,0.75)">
			微信扫码分享
		</div>
		<div style="background:white;padding:12px;border-radius:12px">
			<img
				src={qrSrc}
				alt="QR Code"
				width="200"
				height="200"
				style="display:block"
				loading="lazy"
			/>
		</div>
		<p style="margin-top:8px;font-size:12px;color:var(--secondary);word-break:break-all;max-width:240px;text-align:center;-webkit-user-select:all;user-select:all">
			{urlStr}
		</p>
		<button
			style="margin-top:12px;padding:4px 16px;height:32px;border-radius:8px;border:none;font-size:12px;font-weight:500;cursor:pointer;background:var(--btn-regular-bg);color:var(--btn-content);transition:all 0.15s"
			onclick="document.getElementById('wechat-overlay').style.display='none'"
			onmouseover="this.style.background='var(--btn-regular-bg-hover)'"
			onmouseout="this.style.background='var(--btn-regular-bg)'"
		>
			关闭
		</button>
	</div>
</div>

<script>
function mountOverlay() {
	let overlay = document.getElementById('wechat-overlay');
	// Remove stale overlay from previous Swup navigation
	const old = document.body.querySelector('#wechat-overlay');
	if (old && old !== overlay) old.remove();
	if (overlay && overlay.parentElement !== document.body) {
		document.body.appendChild(overlay);
	}
}
mountOverlay();
const setup = () => {
	if (window.swup) {
		window.swup.hooks.on('page:view', mountOverlay);
	}
};
if (window.swup) {
	setup();
} else {
	document.addEventListener('swup:enable', setup);
}
</script>
