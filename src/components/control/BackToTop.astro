---
import { Icon } from "astro-icon/components";
---

<div id="nav-buttons-wrapper" class="nav-buttons-wrapper hidden lg:block">
	<div id="back-to-top-btn" class="nav-fab hide" onclick="backToTop()" aria-label="Back to Top">
		<Icon name="material-symbols:keyboard-arrow-up-rounded" />
	</div>
	<div id="go-to-bottom-btn" class="nav-fab hide" onclick="goToBottom()" aria-label="Go to Bottom">
		<Icon name="material-symbols:keyboard-arrow-down-rounded" />
	</div>
</div>

<style lang="stylus">
// ── 按钮容器 ─────────────────────────────────────────────────
.nav-buttons-wrapper
	position: fixed
	right: 1.5rem
	bottom: 8rem
	display: flex
	flex-direction: column
	gap: 0.75rem
	z-index: 40
	pointer-events: none

// ── 单个 FAB ─────────────────────────────────────────────────
.nav-fab
	pointer-events: auto
	width: 2.75rem
	height: 2.75rem
	border-radius: 50%
	display: flex
	align-items: center
	justify-content: center
	cursor: pointer
	position: relative
	color: var(--primary)
	font-size: 1.5rem
	border: none
	user-select: none
	-webkit-tap-highlight-color: transparent

	/* 玻璃拟态（Glassmorphism） */
	background: rgba(255, 255, 255, 0.70)
	backdrop-filter: blur(14px)
	-webkit-backdrop-filter: blur(14px)
	border: 1px solid rgba(255, 255, 255, 0.35)

	/* 浮起阴影 */
	box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06), 0 6px 20px rgba(0, 0, 0, 0.08)

	/* 所有状态变化使用弹簧缓动 */
	transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
	            opacity 0.35s ease,
	            box-shadow 0.3s ease,
	            background 0.3s ease

	/* 默认：右边缘露出半圆 */
	transform: translateX(calc(50% + 1.375rem))
	opacity: 0.65

	/* ── 悬浮呼吸动画 ── */
	animation: nav-fab-float 3s ease-in-out infinite

	&:nth-child(2)
		animation-delay: 1.5s

	/* 悬浮：完全滑入 + 放大 + 发光 */
	&:hover
		transform: translateX(0) scale(1.15)
		background: rgba(255, 255, 255, 0.92)
		border-color: var(--primary)
		box-shadow: 0 4px 16px rgba(0, 0, 0, 0.10),
		            0 12px 40px rgba(0, 0, 0, 0.14)

	/* 点击反馈 */
	&:active
		transform: translateX(0) scale(0.92)

	/* 隐藏状态：滑出右侧屏幕 */
	&.hide
		transform: translateX(calc(100% + 3rem))
		opacity: 0
		pointer-events: none

// ── 深色模式 ──────────────────────────────────────────────────
:root.dark .nav-fab
	background: rgba(28, 20, 38, 0.75)
	border-color: rgba(255, 255, 255, 0.06)
	box-shadow: 0 2px 8px rgba(0, 0, 0, 0.25), 0 6px 20px rgba(0, 0, 0, 0.35)

	&:hover
		background: rgba(40, 30, 55, 0.90)
		border-color: var(--primary)
		box-shadow: 0 4px 16px rgba(0, 0, 0, 0.35),
		            0 12px 40px rgba(0, 0, 0, 0.45)

// ── 关键帧 ────────────────────────────────────────────────────
@keyframes nav-fab-float
	0%, 100%
		margin-top: 0
	50%
		margin-top: -4px
</style>

<script is:raw is:inline>
function backToTop() {
	window.scroll({ top: 0, behavior: 'smooth' });
}

function goToBottom() {
	var waline = document.getElementById('waline-container');
	if (waline) {
		waline.scrollIntoView({ behavior: 'smooth', block: 'start' });
	} else {
		window.scroll({ top: document.body.scrollHeight, behavior: 'smooth' });
	}
}
</script>
