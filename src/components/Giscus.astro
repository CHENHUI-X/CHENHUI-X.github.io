---
import { giscusConfig } from "src/config";

const {
	enable,
	repo,
	repoId,
	category,
	categoryId,
	mapping = "pathname",
	reactionsEnabled = true,
	inputPosition = "bottom",
	lang = "zh-CN",
} = giscusConfig;

// 自定义主题 CSS 的公开 URL（Giscus 需要能直接访问）
const siteOrigin = Astro.site ? Astro.site.origin : "https://xuchenhui.cc";
const lightTheme = `${siteOrigin}/css/giscus-light.css`;
const darkTheme = `${siteOrigin}/css/giscus-dark.css`;
---

{enable && repoId && categoryId && (
	<div class="mt-8 rounded-[var(--radius-large)] bg-[var(--card-bg)] overflow-hidden transition">
		<div class="px-6 md:px-9 pt-6 pb-1">
			<div class="flex items-center gap-2 mb-1">
				<div class="flex items-center justify-center w-7 h-7 rounded-md bg-[var(--btn-regular-bg)] text-[var(--btn-content)]">
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
				</div>
				<span class="text-sm font-medium text-[var(--secondary)]">评论</span>
			</div>
		</div>
		<div class="px-6 md:px-9 pb-6" id="giscus-wrapper">
		</div>
	</div>
)}

<script define:vars={{ repo, repoId, category, categoryId, mapping, reactionsEnabled, inputPosition, lang, lightTheme, darkTheme }}>

// 判断当前是否暗色模式
function isDark() {
	return document.documentElement.classList.contains('dark');
}

function getThemeUrl() {
	return isDark() ? darkTheme : lightTheme;
}

// 向 Giscus iframe 发送主题切换消息
function sendThemeToGiscus(themeUrl) {
	const iframe = document.querySelector('iframe.giscus-frame');
	if (!iframe) return;
	iframe.contentWindow.postMessage(
		{ giscus: { setConfig: { theme: themeUrl } } },
		'https://giscus.app'
	);
}

function initGiscus() {
	const wrapper = document.getElementById('giscus-wrapper');
	if (!wrapper) return;
	if (wrapper.querySelector('iframe')) return;

	const script = document.createElement('script');
	script.src = 'https://giscus.app/client.js';
	script.setAttribute('data-repo', repo);
	script.setAttribute('data-repo-id', repoId);
	script.setAttribute('data-category', category);
	script.setAttribute('data-category-id', categoryId);
	script.setAttribute('data-mapping', mapping);
	script.setAttribute('data-strict', '0');
	script.setAttribute('data-reactions-enabled', reactionsEnabled ? '1' : '0');
	script.setAttribute('data-emit-metadata', '0');
	script.setAttribute('data-input-position', inputPosition);
	script.setAttribute('data-theme', getThemeUrl());
	script.setAttribute('data-lang', lang);
	script.setAttribute('crossorigin', 'anonymous');
	script.async = true;
	wrapper.appendChild(script);
}

function destroyGiscus() {
	const wrapper = document.getElementById('giscus-wrapper');
	if (!wrapper) return;
	const iframe = wrapper.querySelector('iframe');
	if (iframe) iframe.remove();
	wrapper.querySelectorAll('script').forEach(s => s.remove());
}

// 监听博客自身的主题切换（setting-utils 里 setTheme 会派发这个事件）
document.addEventListener('theme-change', () => {
	sendThemeToGiscus(getThemeUrl());
});

// 也监听系统主题变化（AUTO 模式下）
window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
	sendThemeToGiscus(getThemeUrl());
});

const setup = () => {
	if (window.swup) {
		window.swup.hooks.on('content:replace', destroyGiscus);
		window.swup.hooks.on('page:view', initGiscus);
	}
};

// 初始化
initGiscus();

if (window.swup) {
	setup();
} else {
	document.addEventListener('swup:enable', setup);
}
</script>
