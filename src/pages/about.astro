---

import { getCollection, getEntry, render } from "astro:content";
import Markdown from "@components/misc/Markdown.astro";
import BlogStats from "@components/widget/BlogStats.astro";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import MainGridLayout from "../layouts/MainGridLayout.astro";

const aboutPost = await getEntry("spec", "about");

if (!aboutPost) {
	throw new Error("About page content not found");
}

const { Content } = await render(aboutPost);

// 统计数据：构建时计算，零运行时开销
const allPosts = await getCollection("posts", ({ data }) => !data.draft);

// 文章数 & 标签数
const postCount = allPosts.length;
const tagCount = new Set(allPosts.flatMap(p => p.data.tags ?? [])).size;

// 全站字数：需要 render() 才能拿到 remarkPluginFrontmatter.words
const wordCounts = await Promise.all(
    allPosts.map(async (p) => {
        const { remarkPluginFrontmatter } = await render(p);
        return (remarkPluginFrontmatter.words as number) ?? 0;
    })
);
const totalWords = wordCounts.reduce((sum, w) => sum + w, 0);

// 最后更新：取所有文章中最新的 updated 或 published
const lastUpdatedDate = allPosts.reduce((latest, p) => {
    const d = p.data.updated ?? p.data.published;
    return d > latest ? d : latest;
}, new Date(0));
const lastUpdated = lastUpdatedDate.toISOString().slice(0, 10);

// 建站日期（固定）& 已运行天数
const FOUNDED = "2025-04-01";
const foundedMs = new Date(FOUNDED).getTime();
const runningDays = Math.floor((Date.now() - foundedMs) / 86400000);
---
<MainGridLayout title={i18n(I18nKey.about)} description={i18n(I18nKey.about)}>
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
        <div class="card-base z-10 px-9 py-6 relative w-full ">
            <Markdown class="mt-2">
                <Content />
            </Markdown>
            <BlogStats
                postCount={postCount}
                tagCount={tagCount}
                totalWords={totalWords}
                foundedDate={FOUNDED}
                lastUpdated={lastUpdated}
                runningDays={runningDays}
            />
        </div>
    </div>
</MainGridLayout>