---
import BackToTop from "@components/control/BackToTop.astro";
import Footer from "@components/Footer.astro";
import Navbar from "@components/Navbar.astro";
import SideBar from "@components/widget/SideBar.astro";
import type { MarkdownHeading } from "astro";
import { Icon } from "astro-icon/components";
import ImageWrapper from "../components/misc/ImageWrapper.astro";
import TOC from "../components/widget/TOC.astro";
import { siteConfig } from "../config";
import {
	BANNER_HEIGHT,
	BANNER_HEIGHT_EXTEND,
	MAIN_PANEL_OVERLAPS_BANNER_HEIGHT,
} from "../constants/constants";
import { url } from "../utils/url-utils";
import Layout from "./Layout.astro";

interface Props {
	title?: string;
	banner?: string;
	description?: string;
	lang?: string;
	setOGTypeArticle?: boolean;
	headings?: MarkdownHeading[];
}

const {
	title,
	banner,
	description,
	lang,
	setOGTypeArticle,
	headings = [],
} = Astro.props;
const hasBannerCredit =
	siteConfig.banner.enable && siteConfig.banner.credit.enable;
const hasBannerLink = !!siteConfig.banner.credit.url;

const mainPanelTop = siteConfig.banner.enable
	? `calc(${BANNER_HEIGHT}vh - ${MAIN_PANEL_OVERLAPS_BANNER_HEIGHT}rem)`
	: "5.5rem";
const isPostsRoute = Astro.url.pathname.startsWith(url("/posts/"));
---

<Layout title={title} banner={banner} description={description} lang={lang} setOGTypeArticle={setOGTypeArticle}>

<!-- Navbar -->
<slot slot="head" name="head"></slot>
<div id="top-row" class="z-50 pointer-events-none relative transition-all duration-700 max-w-[var(--page-width)] px-0 md:px-4 mx-auto" class:list={[""]}>
    <div id="navbar-wrapper" class="pointer-events-auto sticky top-0 transition-all">
        <Navbar></Navbar>
    </div>
</div>

<!-- Banner -->
{siteConfig.banner.enable && <div id="banner-wrapper" class={`absolute z-10 w-full transition duration-700 overflow-hidden`} style={`top: -${BANNER_HEIGHT_EXTEND}vh`}>
    <ImageWrapper id="banner" alt="Banner image of the blog" class:list={["object-cover h-full transition duration-700 opacity-0 scale-105"]}
                  src={siteConfig.banner.src} position={siteConfig.banner.position}
    >
    </ImageWrapper>
</div>}

<!-- Main content -->
<div class="absolute w-full z-30 pointer-events-none" style={`top: ${mainPanelTop}`}>
    <!-- The pointer-events-none here prevent blocking the click event of the TOC -->
    <div class="relative max-w-[var(--page-width)] mx-auto pointer-events-auto">
        <div id="main-grid" class="transition duration-700 w-full left-0 right-0 grid grid-cols-[14rem_auto] grid-rows-[auto_1fr_auto] lg:grid-rows-[auto]
    mx-auto gap-4 px-0 md:px-4"
        >
            <!-- Banner image credit -->
            {hasBannerCredit && <a href={siteConfig.banner.credit.url} id="banner-credit" target="_blank" rel="noopener" aria-label="Visit image source"
                                   class:list={["group onload-animation transition-all absolute flex justify-center items-center rounded-full " +
                                   "px-3 right-4 -top-[3.25rem] bg-black/60 hover:bg-black/70 h-9", {"hover:pr-9 active:bg-black/80": hasBannerLink}]}
            >
                <Icon class="text-white/75 text-[1.25rem] mr-1" name="material-symbols:copyright-outline-rounded" ></Icon>
                <div class="text-white/75 text-xs">{siteConfig.banner.credit.text}</div>
                <Icon class:list={["transition absolute text-[oklch(0.75_0.14_var(--hue))] right-4 text-[0.75rem] opacity-0",
                    {"group-hover:opacity-100": hasBannerLink}]}
                      name="fa6-solid:arrow-up-right-from-square">
                </Icon>
            </a>}


            <div id="toc-left-wrapper"
                 class:list={["hidden lg:block mb-4 row-start-2 row-end-3 col-span-2 lg:row-start-1 lg:row-end-2 lg:col-span-1 lg:max-w-[14rem] onload-animation"]}
            >
                {!isPostsRoute && (
                    <SideBar class="" headings={headings}></SideBar>
                )}
                {isPostsRoute && headings.length > 0 && (
                    <div id="toc-left-inner" class="sticky top-24 transition-swup-fade">
                        <div class="card-base !overflow-visible">
                            <div class="overflow-y-auto max-h-[calc(100vh-10rem)] hide-scrollbar px-3 md:px-4 py-4">
                                <TOC headings={headings} />
                            </div>
                        </div>
                    </div>
                )}
            </div>

            <main id="swup-container" class="transition-swup-fade col-span-2 lg:col-span-1 overflow-hidden">
                <div id="content-wrapper">
                    <!-- the overflow-hidden here prevent long text break the layout-->
                    <!-- make id different from windows.swup global property -->
                    <slot></slot>
                    <div class="footer col-span-2 hidden lg:block">
                        <Footer></Footer>
                    </div>
                </div>
            </main>

            <div class="footer col-span-2 onload-animation block lg:hidden">
                <Footer></Footer>
            </div>
        </div>

        <BackToTop></BackToTop>
    </div>
</div>

<!-- The things that should be under the banner, only the TOC for now -->
{!isPostsRoute && <div class="absolute w-full z-10 hidden xl:block">
    <div class="relative max-w-[var(--page-width)] mx-auto">
        <!-- TOC component -->
        {siteConfig.toc.enable && <div id="toc-wrapper" class:list={["hidden lg:block transition absolute top-0 -right-[var(--toc-width)] w-[var(--toc-width)] items-center",
            {"toc-hide": siteConfig.banner.enable}]}
        >
            <div id="toc-inner-wrapper" class="fixed top-14 w-[var(--toc-width)] h-[calc(100vh_-_20rem)] overflow-y-scroll overflow-x-hidden hide-scrollbar">
                <div id="toc" class="w-full h-full transition-swup-fade ">
                    <div class="h-8 w-full"></div>
                    <TOC headings={headings}></TOC>
                    <div class="h-8 w-full"></div>
                </div>
            </div>
        </div>}

        <!-- #toc needs to exist for Swup to work normally -->
        {!siteConfig.toc.enable && <div id="toc"></div>}
    </div>
</div>}
<!-- #toc 空占位：供 Swup SPA 导航使用，必须始终存在 -->
<div id="toc" style="display:none"></div>

<!-- ===== 移动端 TOC ===== -->
{isPostsRoute && headings.length > 0 && (
  <>
  <!-- 悬浮按钮 -->
  <button id="mobile-toc-btn"
    class="fixed bottom-6 right-5 z-[45] lg:hidden flex items-center justify-center w-11 h-11 rounded-full cursor-pointer
      border-none select-none -webkit-tap-highlight-color-transparent text-[1.3rem]"
    style="background:rgba(255,255,255,0.70);backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);
      border:1px solid rgba(255,255,255,0.35);box-shadow:0 2px 8px rgba(0,0,0,0.06),0 6px 20px rgba(0,0,0,0.08);
      color:var(--primary);
      transition:transform 0.4s cubic-bezier(0.34,1.56,0.64,1),opacity 0.35s ease,box-shadow 0.3s ease"
    aria-label="目录"
  >📖</button>

  <!-- 抽屉遮罩 -->
  <div id="mobile-toc-overlay"
    class="fixed inset-0 z-[48] lg:hidden"
    style="background:rgba(0,0,0,0.4);opacity:0;pointer-events:none;transition:opacity 0.3s ease"
  >
    <!-- 抽屉面板 -->
    <div id="mobile-toc-panel"
      class="absolute right-0 top-0 h-full shadow-2xl"
      style="width:85vw;max-width:320px;background:var(--card-bg);transform:translateX(100%);transition:transform 0.35s cubic-bezier(0.25,1,0.5,1)"
    >
      <!-- 头部 -->
      <div class="flex items-center justify-between px-5 py-4"
        style="border-bottom:1px solid var(--line-color)"
      >
        <span class="font-bold text-base" style="color:var(--primary)">📖 目录</span>
        <button id="mobile-toc-close"
          class="w-8 h-8 flex items-center justify-center rounded-full cursor-pointer border-none text-sm select-none"
          style="background:transparent;color:var(--text-50);transition:background 0.2s ease"
          aria-label="关闭目录"
        >✕</button>
      </div>
      <!-- 列表 -->
      <div id="mobile-toc-list"
        class="overflow-y-auto px-3 py-2"
        style="height:calc(100% - 3.5rem)"
      ></div>
    </div>
  </div>
  </>
)}

<script is:inline>
(function(){'use strict';
// 先把按钮和遮罩移到 body 下，避免 will-change:transform 破坏 fixed 定位
var b=document.getElementById('mobile-toc-btn');
var o=document.getElementById('mobile-toc-overlay');
var l=document.getElementById('mobile-toc-list');
var cb=document.getElementById('mobile-toc-close');
if(!b||!o||!l||!cb)return;
document.body.appendChild(b);
document.body.appendChild(o);
// 重新获取（DOM 移动后 ID 不变）
b=document.getElementById('mobile-toc-btn');
o=document.getElementById('mobile-toc-overlay');

function build(){
    var all=document.querySelectorAll('h2:not(#mobile-toc-list h2),h3:not(#mobile-toc-list h3)');
  var hs=[];
  all.forEach(function(h){
    if(h.closest('#navbar-wrapper')||h.closest('#toc-left-wrapper')||h.closest('#toc-wrapper')||h.closest('#mobile-toc-overlay'))return;
    hs.push(h);
  });
  if(hs.length<2){b.style.display='none';return;}
  // PC端(>=1024px)不显示移动端TOC按钮，左侧已有侧栏目录
  if(window.innerWidth>=1024){b.style.display='none';return;}
  b.style.display='flex';
  l.innerHTML='';
  hs.forEach(function(h){
    var id=h.id||h.textContent.trim().toLowerCase().replace(/[^\w\u4e00-\u9fff]+/g,'-');
    if(!h.id)h.id=id;
    var a=document.createElement('a');
    a.href='#'+id;
    a.className='block py-2.5 px-3 rounded-lg text-sm transition-colors';
    a.style.cssText='color:var(--text-50);text-decoration:none;'+(h.tagName==='H3'?'padding-left:1.5rem;':'');
    a.textContent=h.textContent;
    a.addEventListener('click',function(e){
      e.preventDefault();
      e.stopPropagation();
      closeDrawer();
      setTimeout(function(){
        var el=document.getElementById(id);
        if(el)el.scrollIntoView({behavior:'smooth',block:'start'});
      },320);
    });
    a.addEventListener('mouseenter',function(){this.style.background='var(--toc-btn-hover)';});
    a.addEventListener('mouseleave',function(){this.style.background='transparent';});
    l.appendChild(a);
  });
}

function openDrawer(){o.style.opacity='1';o.style.pointerEvents='auto';o.querySelector('#mobile-toc-panel').style.transform='translateX(0)';}
function closeDrawer(){o.style.opacity='0';o.style.pointerEvents='none';o.querySelector('#mobile-toc-panel').style.transform='translateX(100%)';}

b.addEventListener('click',openDrawer);
cb.addEventListener('click',closeDrawer);
o.addEventListener('click',function(e){if(e.target===o)closeDrawer();});

build();
document.addEventListener('page:view',build);
})();
</script>

</Layout>


